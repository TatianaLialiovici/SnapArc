# Arc Testnet RPC (optional, defaults are provided)
ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# Private key for Hardhat CLI deployments and agents.
# Only use your own key. Never commit this file.
PRIVATE_KEY=

# Agent wallet used by the buyer agent to simulate purchases.
AGENT_PRIVATE_KEY=

# Photographer address used by the royalty agent to filter earnings.
AGENT_PHOTOGRAPHER_ADDRESS=

# Starting block for royalty agent event filtering.
FROM_BLOCK=0

# Pinata JWT for IPFS photo uploads (optional, you can paste a direct URL instead).
NEXT_PUBLIC_PINATA_JWT=

# WalletConnect project ID (optional, only if you enable WalletConnect in wagmi config).
NEXT_PUBLIC_WC_PROJECT_ID=
